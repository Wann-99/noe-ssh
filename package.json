{
  "name": "noe-ssh",
  "version": "1.3.1",
  "description": "SSH Visual Interface",
  "main": "electron/main.js",
  "author": "Wann-99 <799045150@qq.com>",
  "license": "MIT",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node src/index.js",
    "dev:client": "npm --prefix client run dev",
    "build:client": "npm --prefix client run build",
    "postinstall": "node scripts/install-client.mjs",
    "prepare:vendor": "node scripts/prepare-vendor.mjs",
    "prepare:app": "node scripts/prepare-app-bundle.mjs",
    "prepare:node": "node scripts/prepare-node-runtime.mjs",
    "prepare:build": "npm run build:client && npm run prepare:app && npm run prepare:node",
    "electron:dev": "npm run build:client && electron .",
    "electron:build": "npm run prepare:build && electron-builder",
    "package:portable": "npm run build:client && node scripts/package-portable.mjs",
    "test:smoke": "node scripts/smoke-test.mjs"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "express": "^4.18.2",
    "socks": "^2.8.3",
    "ssh2": "^1.14.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "archiver": "^7.0.1",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "playwright": "^1.60.0"
  },
  "build": {
    "appId": "com.wann99.noessh",
    "productName": "Noe-SSH",
    "npmRebuild": false,
    "publish": [
      {
        "provider": "github",
        "owner": "Wann-99",
        "repo": "noe-ssh",
        "releaseType": "release"
      }
    ],
    "directories": {
      "output": "dist/electron",
      "buildResources": "electron/icons"
    },
    "files": [
      "electron/**/*",
      "package.json",
      "node_modules/electron-updater/**/*",
      "node_modules/builder-util-runtime/**/*",
      "node_modules/fs-extra/**/*",
      "node_modules/jsonfile/**/*",
      "node_modules/universalify/**/*",
      "node_modules/graceful-fs/**/*",
      "node_modules/js-yaml/**/*",
      "node_modules/argparse/**/*",
      "node_modules/semver/**/*",
      "node_modules/tiny-typed-emitter/**/*",
      "node_modules/lazy-val/**/*",
      "node_modules/lodash.escaperegexp/**/*",
      "node_modules/lodash.isequal/**/*",
      "node_modules/sax/**/*",
      "node_modules/debug/**/*",
      "node_modules/ms/**/*"
    ],
    "extraResources": [
      {
        "from": "build/app",
        "to": "app"
      },
      {
        "from": "build/node",
        "to": "node"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Noe-SSH-${version}-win-${arch}-${target}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "Noe-SSH-${version}-win-${arch}-Setup.${ext}"
    },
    "portable": {
      "artifactName": "Noe-SSH-${version}-win-${arch}-Portable.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools",
      "artifactName": "Noe-SSH-${version}-mac-${arch}.${ext}"
    },
    "dmg": {
      "artifactName": "Noe-SSH-${version}-mac-${arch}.dmg"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Network",
      "maintainer": "Wann-99 <799045150@qq.com>",
      "artifactName": "Noe-SSH-${version}-linux-${arch}.${ext}"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Wann-99/noe-ssh.git"
  },
  "homepage": "https://github.com/Wann-99/noe-ssh",
  "bugs": {
    "url": "https://github.com/Wann-99/noe-ssh/issues"
  }
}
