# 应用端口（映射到宿主机）
PORT=3000

# Docker / 自托管访问口令（强烈建议设置）。留空则不做服务端鉴权（仅适合本机桌面）
NOE_SSH_ACCESS_TOKEN=change-me-to-a-long-random-secret

# X11 转发目标显示器（可选；默认使用进程环境 DISPLAY）
# 桌面 Linux 示例: :0
# Docker 需挂载 /tmp/.X11-unix 并设置 NOE_SSH_X11_DISPLAY=:0
# NOE_SSH_X11_DISPLAY=:0

# 基础镜像。国内网络无法访问 Docker Hub 时使用下方镜像源（默认已配置）
# 官方源（需能访问 auth.docker.io）:
# NODE_IMAGE=node:20-alpine
NODE_IMAGE=docker.m.daocloud.io/library/node:20-alpine

# npm 安装依赖时的 registry（可选）
NPM_REGISTRY=https://registry.npmmirror.com
USE_CN_MIRROR=1
