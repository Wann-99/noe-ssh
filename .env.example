# 应用端口（映射到宿主机）
PORT=3000

# 推荐：账号模式（Docker / 多人共享）。首次启动创建管理员：
NOE_SSH_ADMIN_USER=admin
NOE_SSH_ADMIN_PASSWORD=admin123

# 数据目录（SQLite：用户与审计）。Docker 默认 /data，并挂载 ./data
NOE_SSH_DATA_DIR=./data

# 遗留单口令模式（未配置管理员且库中无用户时可用）
# NOE_SSH_ACCESS_TOKEN=change-me-to-a-long-random-secret

# X11 转发目标显示器（可选；默认使用进程环境 DISPLAY）
# 桌面 Linux 示例: :0
# Docker 需挂载 /tmp/.X11-unix 并设置 NOE_SSH_X11_DISPLAY=:0
# NOE_SSH_X11_DISPLAY=:0

# 基础镜像（需 Node >= 22，配合 better-sqlite3）。国内默认用 DaoCloud 代理：
# NODE_IMAGE=node:22-bookworm-slim
NODE_IMAGE=docker.m.daocloud.io/library/node:22-bookworm-slim

# npm 安装依赖时的 registry（可选）
NPM_REGISTRY=https://registry.npmmirror.com
USE_CN_MIRROR=1
