# 推荐：账号模式（首次启动用管理员密码初始化用户库）
NOE_SSH_ADMIN_USER=admin
NOE_SSH_ADMIN_PASSWORD=

# 遗留：单口令模式（未设置管理员密码且库中无用户时生效）
# NOE_SSH_ACCESS_TOKEN=

# SQLite 数据目录（容器内默认 /data，compose 已挂载 ./data）
# NOE_SSH_DATA_DIR=/data

# 可选：宿主机端口，默认 3000
# PORT=3000

# X11：compose 已自动挂载 X11 socket 并默认 :0，一般不用改
# NOE_SSH_X11_DISPLAY=:1
# DISPLAY=:1
